  const isValidImageUrl = (url: string | null): boolean => {
    return !!url && 
      typeof url === 'string' && 
      (url.startsWith('http://') || url.startsWith('https://'));
  };
  
  // Check if we have a valid URL for the image
  const hasValidUrl = isValidImageUrl(gig.image);
  
  console.log(`🖼️ Processing image for ${gig.title}`, hasValidUrl ? `Has valid URL: ${gig.image}` : 'No valid URL');e if we have a valid URL to use
  const hasValidUrl = gig.image && 
    typeof gig.image === 'string' && 
    (gig.image.startsWith('http://') || gig.image.startsWith('https://'));
  
  console.log(`🖼️ Processing image for ${gig.title}`, hasValidUrl ? `Has valid URL: ${gig.image}` : 'No valid URL');
  
  // Display stars based on rating, StyleSheet, Text, TouchableOpacity, View } from 'react-native';
import { Theme } from '../../constants/theme';

interface GigCardProps {
  gig: {
    id: string;
    title: string;
    description: string;
    price: string;
    image: string | null;
    images?: string[];
    category?: string;
    categoryName?: string;
    providerName?: string;
    rating?: number;
    reviewCount?: number;
  };
  onPress: (gigId: string) => void;
  onBuy: (gigId: string) => void;
}

export const GigCard: React.FC<GigCardProps> = ({ gig, onPress, onBuy }) => {
  // State for tracking image loading
  const [imageError, setImageError] = React.useState(false);
  
  // Define image sources for different categories
  const categoryImages = {
    music: require('../../../assets/images/third.jpg'),
    musique: require('../../../assets/images/third.jpg'),
    photography: require('../../../assets/images/first.jpeg'),
    photographie: require('../../../assets/images/first.jpeg'),
    catering: require('../../../assets/images/fourth.jpeg'),
    traiteur: require('../../../assets/images/fourth.jpeg'),
    wedding: require('../../../assets/images/secend.jpg'),
    mariage: require('../../../assets/images/secend.jpg'),
    default: require('../../../assets/images/splash-icon.png')
  };
  
  // Function to get a category image
  const getCategoryImage = (category?: string) => {
    if (!category) return categoryImages.default;
    const lowerCategory = category.toLowerCase();
    // @ts-ignore - TypeScript doesn't understand dynamic access
    return categoryImages[lowerCategory] || categoryImages.default;
  };
  
  // Determine if we have a valid URL to use
  const hasValidUrl = gig.image && 
    typeof gig.image === 'string' && 
    (gig.image.startsWith('http://') || gig.image.startsWith('https://'));
  
  console.log(`� Processing image for ${gig.title}`, hasValidUrl ? `Has valid URL: ${gig.image}` : 'No valid URL');
  
  // Display stars based on rating
  const renderStars = (rating: number = 0) => {
    // Ensure rating is a valid number
    const validRating = typeof rating === 'number' && !isNaN(rating) ? rating : 0;
    // Calculate star components
    const fullStars = Math.floor(validRating);
    const halfStar = validRating % 1 >= 0.5;
    const emptyStars = 5 - fullStars - (halfStar ? 1 : 0);
    
    return (
      <View style={styles.starsContainer}>
        {[...Array(fullStars)].map((_, i) => (
          <Text key={`full-${i}`} style={styles.star}>★</Text>
        ))}
        {halfStar && <Text style={styles.star}>★</Text>}
        {[...Array(emptyStars)].map((_, i) => (
          <Text key={`empty-${i}`} style={[styles.star, styles.emptyStar]}>☆</Text>
        ))}
        {validRating > 0 ? (
          <Text style={styles.reviewCount}>({validRating.toFixed(1)})</Text>
        ) : null}
      </View>
    );
  };
  
  // Render different image sources based on what's available
  return (
    <TouchableOpacity onPress={() => onPress(gig.id)} style={styles.container}>
      <View style={styles.imageContainer}>
        {hasValidUrl ? (
          // If we have a valid URL, try to load it with a fallback
          <Image 
            source={{ uri: gig.image }} 
            style={styles.image}
            // If remote image fails, use the category-based local image
            onError={(error) => {
              console.error(`❌ Error loading remote image: ${gig.image}`, error.nativeEvent.error);
              setImageError(true);
            }}
            onLoad={() => console.log(`✅ Successfully loaded image for ${gig.title}`)}
            defaultSource={getCategoryImage(gig.category)}
          />
        ) : (
          // If no valid URL, use category image directly
          <Image 
            source={getCategoryImage(gig.category)} 
            style={styles.image}
            onLoad={() => console.log(`✅ Using local image for ${gig.title}`)}
          />
        )}
        {imageError && (
          // If remote image failed, show local image
          <Image 
            source={getCategoryImage(gig.category)} 
            style={styles.image}
          />
        )}
        {gig.category && (
          <View style={styles.categoryBadge}>
            <Text style={styles.categoryText}>
              {gig.categoryName || gig.category}
            </Text>
          </View>
        )}
      </View>
      
      <View style={styles.content}>
        <Text style={styles.title} numberOfLines={1} ellipsizeMode="tail">{gig.title}</Text>
        
        {gig.providerName && (
          <Text style={styles.provider} numberOfLines={1}>
            By {gig.providerName}
          </Text>
        )}
        
        <Text style={styles.description} numberOfLines={2} ellipsizeMode="tail">
          {gig.description}
        </Text>
        
        <View style={styles.footer}>
          <View style={styles.ratingContainer}>
            {renderStars(gig.rating)}
            <Text style={styles.reviews}>
              {gig.reviewCount && gig.reviewCount > 0 
                ? `${gig.reviewCount} ${gig.reviewCount === 1 ? 'review' : 'reviews'}`
                : 'No reviews yet'}
            </Text>
          </View>
          
          <TouchableOpacity 
            style={styles.bookButton}
            onPress={() => onBuy(gig.id)}
          >
            <Text style={styles.buyButtonText}>Book Now</Text>
          </TouchableOpacity>
        </View>
      </View>
    </TouchableOpacity>
  );
};

const styles = StyleSheet.create({
  container: {
    width: '100%',
    overflow: 'hidden',
    borderRadius: Theme.borderRadius.md,
    backgroundColor: '#FFFFFF',
    shadowColor: "#000",
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.1,
    shadowRadius: 4,
    elevation: 3,
    marginBottom: 16,
  },
  imageContainer: {
    position: 'relative',
    width: '100%',
  },
  image: {
    width: '100%',
    height: 180,
    resizeMode: 'cover',
  },
  categoryBadge: {
    position: 'absolute',
    top: 12,
    right: 12,
    backgroundColor: 'rgba(0, 0, 0, 0.6)',
    paddingHorizontal: 10,
    paddingVertical: 4,
    borderRadius: 16,
  },
  categoryText: {
    fontFamily: Theme.typography.fontFamily.medium,
    fontSize: Theme.typography.fontSize.xs,
    color: '#FFFFFF',
  },
  content: {
    padding: Theme.spacing.md,
  },
  title: {
    fontFamily: Theme.typography.fontFamily.semiBold,
    fontSize: Theme.typography.fontSize.md,
    color: Theme.colors.textDark,
    marginBottom: 4,
  },
  provider: {
    fontFamily: Theme.typography.fontFamily.regular,
    fontSize: Theme.typography.fontSize.xs,
    color: Theme.colors.textLight,
    marginBottom: 8,
  },
  description: {
    fontFamily: Theme.typography.fontFamily.regular,
    fontSize: Theme.typography.fontSize.sm,
    color: Theme.colors.textLight,
    marginBottom: 12,
    lineHeight: 18,
  },
  footer: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'flex-end',
    marginTop: 8,
  },
  starsContainer: {
    flexDirection: 'row',
    alignItems: 'center',
  },
  star: {
    color: Theme.colors.warning,
    fontSize: 14,
    marginRight: 1,
  },
  emptyStar: {
    color: '#D1D5DB',
  },
  reviewCount: {
    fontFamily: Theme.typography.fontFamily.regular,
    fontSize: 12,
    color: Theme.colors.textLight,
    marginLeft: 4,
  },
  reviews: {
    fontFamily: Theme.typography.fontFamily.regular,
    fontSize: 12,
    color: Theme.colors.textLight,
    marginTop: 2,
  },
  ratingContainer: {
    flexDirection: 'column',
  },
  bookButton: {
    backgroundColor: Theme.colors.primary,
    paddingHorizontal: 18,
    paddingVertical: 8,
    borderRadius: 16,
    alignSelf: 'flex-end',
  },
  buyButtonText: {
    fontFamily: Theme.typography.fontFamily.medium,
    fontSize: Theme.typography.fontSize.sm,
    color: '#FFFFFF',
  },
});